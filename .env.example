SECRET_KEY=change-me-in-production ## para generar este ejecuta $ openssl rand -hex 32
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ────────────────────────────────────────────────────────────
# Opción A: variables sueltas (local / Docker)
DB_NAME=dts_delivery
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Opción B: URL completa (Railway, Render, etc.) — tiene prioridad sobre DB_*
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
#
# ── Railway (producción) ─────────────────────────────────────────────────────
# Guía completa: docs/DEPLOY_RAILWAY.md
#
# En el servicio DTS-backend (dentro de Railway):
#   DATABASE_URL=${{postgis.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   ALLOWED_HOSTS=.up.railway.app,tu-servicio.up.railway.app
#   DEBUG=False
#   MEDIA_PUBLIC_BASE_URL=https://tu-servicio.up.railway.app
#
# Desde Mac/local: usa URL TCP pública de PostGIS (no *.railway.internal)

# Docker (make docker-up-full): DB_HOST=db, REDIS_URL=redis://redis:6379/0, EMAIL_HOST=mailpit

REDIS_URL=redis://localhost:6379/0

# Email — Mailpit (docker compose up mailpit)
# UI: http://localhost:8025  |  SMTP: localhost:1025
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@dts.local

# Firebase Cloud Messaging — Fase 2 (T2.4.x)
# Descargar JSON desde Firebase Console → Service accounts
# FCM_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# PostGIS requiere GDAL/GEOS instalados en el sistema (macOS: brew install gdal geos)
# GDAL_LIBRARY_PATH=/opt/homebrew/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/lib/libgeos_c.dylib

# Medios — local (dev) o S3 (prod). Ver docs/MEDIA_STORAGE.md
MEDIA_STORAGE_BACKEND=local
SERVE_MEDIA=True
MEDIA_PUBLIC_BASE_URL=http://localhost:8000
# MEDIA_STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
